# Optional: Google Maps Platform API key with Weather API enabled.
# Copy to ".env.local" (gitignored) — never commit real keys.
# Restrict the key in Google Cloud Console (HTTP referrers for this app’s origin).
VITE_GOOGLE_MAPS_API_KEY=

# Optional: Plant safety prediction endpoint (AWS API Gateway + Lambda).
# If unset, the app uses the default hosted endpoint.
VITE_PREDICT_API_URL=

# Optional: Vite public path (must start and end with `/`). Pages: root = branch `production`, /iteration2/ = `main`.
# Local: npm run dev (/) or VITE_BASE_PATH=/iteration2/ npm run dev → http://localhost:5173/iteration2/
VITE_BASE_PATH=

# PostgreSQL recommendations API (see `server/index.mjs`). Used when you run `npm run dev:api` or deploy the API.
# Put this in `.env.local` (gitignored) alongside your Vite keys. The API loads `.env` then `.env.local`.
# Example: postgresql://postgres:PASSWORD@database-1.xxxxx.ap-southeast-2.rds.amazonaws.com:5432/postgres?sslmode=require
DATABASE_URL=

# Optional: full origin of the deployed API (GitHub Pages cannot talk to RDS directly). If unset, the app uses /api (Vite proxy in dev).
VITE_API_BASE_URL=

# Firebase Authentication (frontend)
# Get these from: Firebase Console → Project settings → Your apps → Web app config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MEASUREMENT_ID=

# Lambda/API only: comma-separated allowed browser origins for CORS (e.g. https://imhero2k.github.io). When set, http://localhost:5173 and http://127.0.0.1:5173 are also allowed for local testing. If you use API Gateway CORS, add the same localhost origins there too.
CORS_ORIGIN=

# DynamoDB: per-user planner layout (`userId` partition key, `layoutId` sort key; default item uses layoutId "default").
# Grant the API/Lambda IAM role dynamodb:GetItem and dynamodb:PutItem on this table.
DYNAMODB_PLANNER_LAYOUT_TABLE=
AWS_REGION=

# Firebase Admin SDK (API/Lambda): verify Bearer ID tokens for /api/planner/layout.
# Set either a JSON string of the service account, or GOOGLE_APPLICATION_CREDENTIALS pointing at the key file.
FIREBASE_SERVICE_ACCOUNT_JSON=
# GOOGLE_APPLICATION_CREDENTIALS=
