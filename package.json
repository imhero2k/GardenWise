{
  "name": "gardenwise",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "node server/index.mjs",
    "dev:all": "concurrently \"npm run dev:api\" \"npm run dev\"",
    "build": "vite build",
    "postbuild": "node -e \"require('fs').copyFileSync('dist/index.html','dist/404.html')\"",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "data:vic-nurseries": "curl -sL 'https://www.google.com/maps/d/kml?mid=1yOtzP69AwraWmug_YTr2BThjLD16yFpa&forcekml=1' | node scripts/kml-placemarks-to-json.mjs > src/data/vic-nurseries.json",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@vendia/serverless-express": "^4.12.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "firebase": "^12.12.0",
    "leaflet": "^1.9.4",
    "pg": "^8.13.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  }
}
